    "page_number": 4,
    "bbox": [
      99.38,
      277.47,
      527.16,
      291.47
    ],
    "text": "of preparation to kill, such as procuring a deadly weapon or selecting a",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
