    "text": "\u0d85\u0dad\u0dca\u0d85\u0da9\u0d82\u0d9c\u0dd4\u0dc0\u0da7 \u0dd9\u0dad\u0dca \u0dc0\u0dd6 \u0d85\u0dd9\u0dbb\u0ddc\u0db0\u0dba\u0da7 \u0dc3\u0db8\u0dca\u0db6\u0db1\u0dca\u0db0 \u0db4 \u0ddc\u0dc0\u0dd4\u0db4\u0dba\u0db1\u0dca \u0daf\u0ddc\u0dba\u0d9a \u0db4 \u0ddc\u0dc0\u0dd6 \u0db6\u0dc0 \u0d9a\u0dc0\u0dbb \u0db4\u0dc4\u0ddd \u0db4\u0dd9\u0ddc\u0dbd\u0dd2\u0dc3\u0dca \u0dc3\u0dca\u0dae\u0ddc \u0dba\u0d9a\u0da7",
