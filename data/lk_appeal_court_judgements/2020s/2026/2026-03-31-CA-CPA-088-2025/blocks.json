    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      122.93,
      526.15,
      135.97
    ],
    "text": "Before the commencement of the trial, the 4th Accused pleaded guilty, and during the",
    "fonts": [
      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      142.73,
