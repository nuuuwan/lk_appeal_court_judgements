    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      660.01,
      198.48,
      673.05
    ],
    "text": "conscience of this Court.",
    "fonts": [
      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      689.89,
      330.26,
      702.93
