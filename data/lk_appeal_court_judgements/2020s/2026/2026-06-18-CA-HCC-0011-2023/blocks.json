    "page_number": 5,
    "bbox": [
      78.02,
      171.72,
      527.28,
      185.72
    ],
    "text": "The Registrar is directed to send this judgment to the High Court of Ampara",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      78.02,
      192.84,
      291.67,
      206.84
    ],
    "text": "along with the original case record.",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
