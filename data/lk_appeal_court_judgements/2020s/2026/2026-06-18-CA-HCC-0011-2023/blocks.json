    "page_number": 5,
    "bbox": [
      302.11,
      286.35,
      527.28,
      300.35
    ],
    "text": "JUDGE OF THE COURT OF APPEAL",
    "fonts": [
      "BookmanOldStyle",
      "BookmanOldStyle-Bold"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      78.02,
      348.51,
      229.97,
      362.49
    ],
    "text": "R. P. Hettiarachchi, J.",
    "fonts": [
      "BookmanOldStyle-Bold"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      78.02,
      379.71,
      124.82,
      393.71
    ],
    "text": "I agree.",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 5,
    "bbox": [
      86.06,
      442.01,
      527.52,
      456.01
    ],
