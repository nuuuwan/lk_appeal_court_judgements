    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      114.62,
      319.71,
      523.44,
      333.77
    ],
    "text": "acquittal of an accused person. The judgment in this case is a well-",
    "fonts": [
      "BookmanOldStyle-Italic"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      114.62,
      340.83,
      257.69,
      354.89
    ],
    "text": "reasoned out judgment.",
