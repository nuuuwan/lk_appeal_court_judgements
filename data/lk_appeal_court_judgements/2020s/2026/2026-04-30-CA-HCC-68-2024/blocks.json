      "Calibri",
      "Calibri-Bold"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      72.05,
      526.5,
      86.22
    ],
    "text": "Sugatha Mama\u2019s house. At that time, the appellant asked her to convey a message",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      93.67,
      526.62,
      107.84
    ],
    "text": "to her brother, but when she stopped, the Appellant pressed a knife against her",
