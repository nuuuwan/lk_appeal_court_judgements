      480.49
    ],
    "text": "conflict with the established Law.",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      108.02,
      499.92,
      526.64,
      514.09
    ],
    "text": "3. The prosecution's failure to meet the beyond-reasonable doubt standard",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
