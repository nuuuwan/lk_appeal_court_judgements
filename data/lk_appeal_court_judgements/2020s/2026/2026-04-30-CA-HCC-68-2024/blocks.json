    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      653.79,
      383.33,
      667.96
    ],
    "text": "The facts and circumstances of this case are as follows,",
