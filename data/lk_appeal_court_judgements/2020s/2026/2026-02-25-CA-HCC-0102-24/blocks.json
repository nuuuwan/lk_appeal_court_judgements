    "fonts": [
      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      91.73,
      241.68,
      104.77
    ],
    "text": "considered the following factors,",
