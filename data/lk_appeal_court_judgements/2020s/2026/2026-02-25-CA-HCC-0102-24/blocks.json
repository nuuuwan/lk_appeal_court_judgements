      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      158.57,
      526.49,
      172.15
    ],
    "text": "\u0dad\u0dd0\u0db1\u0dd0\u0dad\u0dca\u0dad\u0dd2\u0dd9\u0db1\u0dca\u0db8\u0dda \u0d91\u0db1\u0dda \u0db4\u0dd0.\u0dc3\u0dcf.01 \u0db8\u0dda \u0dc3\u0dc4 \u0db4\u0dd0.\u0dc3\u0dcf.02 \u0db8\u0dda \u0dc0\u0dd9\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 7 \u0d9a\u0dca \u0db6\u0dc0 \u0db8\u0db4\u0db1\u0dd3 \u0dd9\u0dba\u0dd2. \u0d92 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7",
