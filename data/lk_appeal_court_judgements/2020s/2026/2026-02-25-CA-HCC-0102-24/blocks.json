    ],
    "text": "\u0d85\u0db0\u0dd2\u0d9a\u0dbb\u0dab\u0dd9 \u0d85\u0dc0\u0dcf\u0db0\u0dcf\u0db1\u0dd9 \u0db8\u0dd9\u0dcf\u0db8\u0dd4 \u0d9a\u0dc5 \u0dba\u0dd4\u0dad\u0dd4 \u0d9a\u0dbb\u0dd4\u0dab \u0dc0\u0db1\u0dca\u0db8\u0db1\u0dca \u0d91\u0dd9 \u0d9a\u0dd4\u0da9\u0dcf \u0db1\u0dd2\u0dc0\u0dd4\u0db1\u0dca \u0dd9\u0dd0\u0dbb\u0dd2\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8\u0dd9\u0db1\u0dcf\u0dd9 \u0d91\u0d9a\u0dd9",
