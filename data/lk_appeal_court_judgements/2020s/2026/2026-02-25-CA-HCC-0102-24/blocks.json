      178.73,
      526.49,
      192.31
    ],
    "text": "\u0dc0\u0dd2\u0dad\u0dca\u0dad\u0dd2\u0d9a\u0dbb\u0dd4\u0db8\u0dda \u0dc0\u0dd9\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 27 \u0d9a\u0dca \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d94\u0dc4\u0dd4 \u0dad\u0dbb\u0dd4\u0dab\u0dd4 \u0dc0\u0dd2\u0db8\u0dda \u0db4\u0dc3\u0dd4 \u0dc0\u0dd6 \u0db8\u0dc4\u0dcf\u0db3\u0dd2\u0db1\u0dca \u0dd9\u0dd0\u0db1\u0dd4\u0dda \u0db8\u0dad\u0dca\u0dbb\u0dd4\u0dda \u0d87\u0dad\u0dd2",
