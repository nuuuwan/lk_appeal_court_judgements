      612.34,
      526.39,
      625.38
    ],
    "text": "14.03.2024 found the Appellant guilty of the 1st and 2nd counts and imposed a sentence of",
    "fonts": [
      "Century"
    ],
    "sizes": [
      6.960000038146973,
      11.039999961853027
    ]
  },
