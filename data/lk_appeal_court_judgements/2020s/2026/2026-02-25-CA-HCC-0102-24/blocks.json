      "Century",
      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      198.89,
      526.49,
      212.47
    ],
    "text": "\u0db4\u0dd4\u0daf\u0dca\u0d9c\u0dbd\u0db8\u0dd9\u0d9a\u0dd4 \u0db6\u0dc0 \u0d89\u0dad\u0dcf \u0db4\u0dd0\u0dc4\u0dd0\u0daf\u0dd2\u0dbd\u0dd2\u0dd9. \u0db1\u0db8\u0dd4\u0dad\u0dca \u0db8\u0dda \u0dc0\u0dd2\u0db1\u0dca\u0daf\u0dd2\u0dad \u0dd9\u0dd0\u0dbb\u0dd2\u0dd9\u0db1\u0dca \u0db8\u0dd9\u0db8\u0dd9\u0db1\u0dcf\u0dd9 \u0d92 \u0dc0\u0db1 \u0dc0\u0dd2\u0da7 2 \u0dc0\u0dc3\u0db8\u0dbb\u0dca \u0d85\u0db0\u0dba\u0dcf\u0db4\u0db1\u0dd9",
    "fonts": [
      "Century",
      "IskoolaPota"
