    "bbox": [
      72.02,
      655.47,
      397.49,
      669.64
    ],
    "text": "The Queen v. Sumanasena, Basnayake, C.J. 66 NLR 350 :",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.24,
      691.11,
      530.36,
      705.28
    ],
    "text": "\u201cIn our opinion the learned Judge's direction is wrong. Suspicious",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      107.24,
      712.71,
      530.32,
      726.88
    ],
    "text": "circumstances do not establish guilt. Nor does the proof of any number of",
