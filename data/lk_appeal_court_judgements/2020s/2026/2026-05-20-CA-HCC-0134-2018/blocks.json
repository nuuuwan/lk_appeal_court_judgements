    "bbox": [
      107.24,
      471.96,
      530.45,
      486.13
    ],
    "text": "\u201c1) The circumstances from which the conclusion was drawn should be fully",
    "fonts": [
      "Century"
    ],
    "sizes": [
      12.0
    ]
  },
