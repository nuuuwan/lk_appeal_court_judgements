      "ArialMT",
      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      90.02,
      380.72,
      348.62,
      393.93
    ],
    "text": "3. The appellant has no previous criminal record.",
    "fonts": [
      "ArialMT",
      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
