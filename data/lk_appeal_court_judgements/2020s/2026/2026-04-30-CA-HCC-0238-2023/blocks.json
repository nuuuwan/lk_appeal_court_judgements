      "Century"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      90.02,
      341.12,
      526.49,
      354.33
    ],
    "text": "1. The appellant is 59 years old, married, and has three children under the age of 18.",
