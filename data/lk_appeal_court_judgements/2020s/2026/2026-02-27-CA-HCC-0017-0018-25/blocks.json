    "fonts": [
      "TimesNewRomanPS-ItalicMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      140.78,
      183.97,
      526.04,
      197.25
    ],
