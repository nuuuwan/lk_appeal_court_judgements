      "ArialMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0,
      14.039999961853027
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      693.81,
      526.09,
      707.09
    ],
