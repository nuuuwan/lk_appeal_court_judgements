      "ArialMT",
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0,
      14.039999961853027
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      231.37,
      526.21,
      244.65
    ],
    "text": "an accused convicted of an offence of sexual abuse. The Court must also take into account",
