    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      90.02,
      376.84,
      526.2,
      390.12
    ],
    "text": "carefully analyzed the factual context of the case, in particular the tender age of the victim,",
