    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      264.53,
      36.28,
      332.8,
      45.18
    ],
    "text": "CA/HCC/0223/2024",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      8.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      779.14,
      526.13,
      805.78
    ],
    "text": "5 | P a g e",
    "fonts": [
      "Calibri"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      90.02,
      72.47,
      526.14,
      85.75
