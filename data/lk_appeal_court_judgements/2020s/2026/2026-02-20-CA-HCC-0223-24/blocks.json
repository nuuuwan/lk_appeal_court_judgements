    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      192.11,
      526.08,
      223.89
    ],
    "text": "10. However, old age alone cannot be considered the sole criterion for extending clemency to",
