    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      93.13,
      526.07,
      106.41
    ],
    "text": "can be considered a mitigating factor warranting a reduction of the sentence imposed on",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      90.02,
      113.89,
      277.01,
      127.17
    ],
    "text": "him by the learned High Court Judge.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      72.02,
      134.53,
      526.15,
      163.89
    ],
    "text": "9. It must be emphasized that advanced age does not excuse criminal conduct, but it remains",
    "fonts": [
      "ArialMT",
