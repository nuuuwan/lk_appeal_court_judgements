      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      90.02,
      173.89,
      526.42,
      187.17
    ],
    "text": "to repeat the conduct when the opportunity arose, thereby demonstrating a disturbing",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      90.02,
      194.65,
      319.99,
      207.93
    ],
    "text": "degree of persistence in his criminal behaviour.",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      215.39,
      526.24,
      247.29
    ],
    "text": "16. Offences of this nature call for sentences that reflect not only the gravity of the wrongdoing",
