      312.59
    ],
    "text": "The Appellant had denied the incident and suggested the same to the",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      78.02,
      319.71,
