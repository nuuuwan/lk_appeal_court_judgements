    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      99.38,
      571.04,
      527.1,
      585.04
    ],
    "text": "Explanation- It is immaterial in such cases which party offers the",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      99.38,
      592.16,
      342.55,
      606.16
    ],
    "text": "provocation or commits the first assault\u201d",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 3,
    "bbox": [
      78.02,
      623.24,
      527.05,
      637.24
    ],
    "text": "The counsel for the Appellant seeks relief lessening the culpability by",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
