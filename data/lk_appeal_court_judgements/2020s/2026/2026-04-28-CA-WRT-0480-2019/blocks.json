    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
  {
    "page_number": 2,
    "bbox": [
      72.02,
      385.29,
      526.42,
      399.6
    ],
    "text": "It is his position that disciplinary proceedings were initiated against him by the 1st",
    "fonts": [
      "TimesNewRomanPSMT"
    ],
    "sizes": [
      8.039999961853027,
      12.0
    ]
  },
