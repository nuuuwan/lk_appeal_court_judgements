      "Century",
      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      225.89,
      526.49,
      239.47
    ],
    "text": "\u0dad\u0dd0\u0db1\u0dd0\u0dad\u0dca\u0dd2\u0dba\u0d9a\u0dca \u0db8\u0dbd\u0dc3 \u0dbb\u0dd4\u0dab\u0dd4 \u0d85\u0db1\u0dcf\u0dc0\u0dbb\u0dab\u0dba \u0dc0\u0db1 \u0d85\u0dad\u0dbb \u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0dca \u0db1\u0dd2\u0dba\u0db8 \u0d9a\u0dd2\u0dbb\u0dd2\u0db8\u0db8\u0dca\u0daf\u0dd3 \u0d85\u0db0\u0dd2 \u0dbb\u0dab\u0dba\u0d9a\u0dca \u0dd2\u0dc3\u0dd2\u0db1\u0dca",
    "fonts": [
      "Century",
      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      245.69,
      526.49,
      259.27
    ],
    "text": "\u0dc3\u0dbd \u0dcf \u0db6\u0dbd\u0db1\u0dca\u0db8\u0db1\u0dca \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0dba \u0dbb\u0db1 \u0dbd\u0daf \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db8\u0dda \u0dbb\u0dd4\u0dab\u0dd4\u0dba. \u0d91\u0dba\u0da7 \u0db8\u0dc4\u0dca\u0dad\u0dd4\u0dc0 \u0dba\u0db8\u0dca\u0d9a\u0dd2\u0dc3\u0dd2 \u0db8\u0dc4\u0dba\u0d9a\u0dd2\u0db1\u0dca \u0db8\u0db8\u0dca",
    "fonts": [
      "Century",
      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      265.85,
      526.49,
      279.43
    ],
    "text": "\u0d86 \u0dcf\u0dbb\u0db8\u0dda \u0d85\u0db4\u0dbb\u0dcf\u0db0\u0dba\u0d9a\u0dca \u0dbb\u0db1\u0dd4 \u0dbd\u0db6\u0db1 \u0da0\u0dd4\u0dd2\u0dad\u0db8\u0dba\u0d9a\u0dd4\u0db8\u0dda \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 18 \u0da7 \u0d85\u0da9\u0dd4 \u0dc0\u0dd4\u0dc0\u0db8\u0dc4\u0dcf\u0dad\u0dca \u0dc3\u0dd2\u0dbb \u0daf\u0da9\u0dd4\u0dc0\u0db8\u0dca \u0db1\u0dd2\u0dba\u0db8",
    "fonts": [
      "Century",
      "IskoolaPota"
