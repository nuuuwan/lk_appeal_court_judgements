    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      186.65,
      526.49,
      200.23
    ],
    "text": "\u0d92 \u0d85\u0db1\u0dd4\u0dc0 \u0db8\u0db8\u0db8 \u0db1\u0da9\u0dd4\u0db8\u0dda \u0da0\u0dd4\u0dd2\u0dad \u0dc0\u0dbb\u0daf \u0db4\u0dd2\u0dbd\u0dd2\u0d9c\u0dd0\u0db1\u0dd3\u0db8, \u0da0\u0dd4\u0dd2\u0dad\u0da7 \u0d85\u0daf\u0dcf\u0dbd \u0d89\u0dc4\u0dd2\u0db1\u0dca \u0dc3\u0dcf \u0da0\u0dca\u0da0\u0da1\u0dcf \u0dbb\u0db1 \u0dbd\u0daf \u0dbb\u0dd4\u0dab\u0dd4 \u0dc0\u0dbd",
    "fonts": [
      "Century",
      "IskoolaPota"
    ],
    "sizes": [
      11.039999961853027
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      108.02,
      206.81,
      526.49,
      220.39
    ],
    "text": "\u0d85\u0daf\u0dcf\u0dbd\u0dad\u0dca\u0dc0\u0dba \u0dc3\u0dd0\u0dbd\u0d9a\u0dd2\u0dbd\u0dca\u0dbd\u0da7 \u0d9c\u0dd0\u0db1\u0dd3\u0db8\u0db8\u0dca\u0daf\u0dd3 \u0dd2\u0db1\u0dca\u0dd2\u0dad \u0db4\u0dcf\u0dbb\u0dca\u0dc1\u0dc0\u0dba \u0d85\u0db4\u0dbb\u0dcf\u0db0 \u0d85\u0dc0\u0dc3\u0dca\u0dae\u0dcf\u0db8\u0dda \u0dc0\u0dba\u0dc3 \u0d85\u0dc0\u0dd4\u0dbb\u0dd4\u0daf\u0dd4 14",
