      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      210.72,
      543.75,
      224.72
    ],
    "text": "It is in this context, I would think it expedient at this juncture to examine the",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      232.08,
      327.67,
      246.08
    ],
    "text": "law governing an application for re-listing.",
