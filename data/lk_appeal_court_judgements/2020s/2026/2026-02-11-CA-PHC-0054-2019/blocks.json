    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      526.61,
      543.93,
      540.61
    ],
    "text": "It is necessary to make a distinction between mistake or inadvertence of an",
    "fonts": [
      "BookmanOldStyle"
    ],
    "sizes": [
      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      547.73,
      543.94,
      561.73
    ],
