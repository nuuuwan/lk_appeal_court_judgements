      12.0
    ]
  },
  {
    "page_number": 4,
    "bbox": [
      72.02,
      261.03,
      544.13,
      275.03
    ],
    "text": "It was laid down by Court in the decision in Packiyanathan V. Singarajah",
    "fonts": [
      "BookmanOldStyle",
      "BookmanOldStyle-Bold"
